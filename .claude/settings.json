{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx --no-install fallow audit 2>&1 || exit 2",
            "timeout": 60,
            "statusMessage": "Running fallow audit"
          }
        ]
      }
    ]
  }
}
